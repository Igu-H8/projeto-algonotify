datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  createdAt DateTime  @default(now())
  bookings  Booking[]
}

model Booking {
  id          String   @id @default(uuid())
  serviceName String   // Ex: "Consulta", "Treino"
  dateTime    DateTime // Data e hora do agendamento
  status      String   @default("PENDING") // PENDING, CONFIRMED, CANCELED
  createdAt   DateTime @default(now())
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}